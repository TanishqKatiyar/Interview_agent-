# ============================================================================
# Cuemath AI Tutor Screener — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# ============================================================================

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── LLM Providers ──────────────────────────────────────────────────────────
# Primary: Groq (Llama 3.3 70B) — https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Fallback + Assessment: Google AI Studio — https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Speech ──────────────────────────────────────────────────────────────────
# Deepgram (STT) — https://deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ─── Email (Optional) ───────────────────────────────────────────────────────
# Resend — https://resend.com (for interview invitation emails)
RESEND_API_KEY=re_your_resend_key_here

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=your-secure-admin-password

# Email to receive assessment completion notifications
ADMIN_NOTIFICATION_EMAIL=admin@yourcompany.com

# ─── App ─────────────────────────────────────────────────────────────────────
# Set this to your deployment URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
